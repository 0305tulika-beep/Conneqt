<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#F5F5F5"/>  <!-- soft white -->

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="#DDDDDD"/>

    <!-- Padding (optional but useful) -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="10dp"
        android:bottom="10dp"/>

</shape>