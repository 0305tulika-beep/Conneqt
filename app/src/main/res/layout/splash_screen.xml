<?xml version="1.0" encoding="utf-8"?>
<!--
    SCREEN 1: SplashActivity
    Shows for 2 seconds on app launch, then navigates to LoginActivity.
    No user interaction on this screen.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <!-- Top glow blob -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp" />

    <!-- Bottom glow blob -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="-80dp"
        android:layout_marginStart="-80dp" />

    <!-- Center Content -->
    <LinearLayout
        android:id="@+id/splashCenterLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <!-- App Icon Box -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="88dp"
            android:layout_height="88dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A2D4A"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="⚡"
                android:textSize="40sp"
                android:gravity="center" />
        </androidx.cardview.widget.CardView>

        <!-- App Name -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conneqt"
                android:textSize="44sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.02" />

            <!-- Blue dot accent -->
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/dot_accent" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart Classroom Bridge"
            android:textSize="14sp"
            android:textColor="#4A90E2"
            android:letterSpacing="0.08"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Bottom loading bar -->
    <LinearLayout
        android:id="@+id/splashBottomLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="48dp"
        android:orientation="vertical"
        android:gravity="center">

        <ProgressBar
            android:id="@+id/splashProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="120dp"
            android:layout_height="3dp"
            android:indeterminate="true"
            android:indeterminateTint="#4A90E2"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="For Educators"
            android:textSize="12sp"
            android:textColor="#3D4557"
            android:letterSpacing="0.1" />

</RelativeLayout>