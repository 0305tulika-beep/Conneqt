<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <!-- Decorative glow -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:paddingTop="64dp"
            android:gravity="center_horizontal">

            <!-- Brand -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Conneqt"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <View
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/dot_accent"/>
            </LinearLayout>

            <TextView
                android:text="Create your educator account"
                android:textSize="13sp"
                android:textColor="#4A90E2"
                android:letterSpacing="0.06"
                android:layout_marginBottom="40dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#141824">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Get Started"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Sign up to continue"
                        android:textSize="13sp"
                        android:textColor="#8892A4"
                        android:layout_marginBottom="28dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <!-- Name -->
                    <TextView
                        android:text="FULL NAME"
                        android:textSize="11sp"
                        android:textColor="#4A90E2"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:hint="Dr. John Doe"
                        android:padding="16dp"
                        android:textColor="#3D4557"
                        android:textColorHint="#B0BEC5"
                        android:background="@drawable/input_bg"
                        android:layout_marginBottom="18dp"/>

                    <!-- Email -->
                    <TextView
                        android:text="EMAIL"
                        android:textSize="11sp"
                        android:textColor="#4A90E2"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:hint="professor@university.edu"
                        android:inputType="textEmailAddress"
                        android:padding="16dp"
                        android:textColor="#3D4557"
                        android:textColorHint="#B0BEC5"
                        android:background="@drawable/input_bg"
                        android:layout_marginBottom="18dp"/>

                    <!-- Password -->
                    <TextView
                        android:text="PASSWORD"
                        android:textSize="11sp"
                        android:textColor="#4A90E2"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:inputType="textPassword"
                        android:hint="••••••••"
                        android:padding="16dp"
                        android:textColor="#3D4557"
                        android:textColorHint="#B0BEC5"
                        android:background="@drawable/input_bg"
                        android:layout_marginBottom="18dp"/>

                    <!-- Confirm Password -->
                    <TextView
                        android:text="CONFIRM PASSWORD"
                        android:textSize="11sp"
                        android:textColor="#4A90E2"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:inputType="textPassword"
                        android:hint="••••••••"
                        android:padding="16dp"
                        android:textColor="#3D4557"
                        android:textColorHint="#B0BEC5"
                        android:background="@drawable/input_bg"
                        android:layout_marginBottom="24dp"/>

                    <!-- Sign Up Button -->
                    <Button
                        android:id="@+id/btnSignup"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="CREATE ACCOUNT"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:background="@drawable/btn_primary"
                        android:layout_marginBottom="12dp"/>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="#4A90E2"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvGoToLogin"
                android:text="Already have an account? Sign in"
                android:textSize="12sp"
                android:textColor="#4A90E2"
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>