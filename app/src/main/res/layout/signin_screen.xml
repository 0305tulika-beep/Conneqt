<?xml version="1.0" encoding="utf-8"?>
<!--
    SCREEN 2: LoginActivity
    Professor enters email + password.
    On success → navigates to MainActivity (which hosts the bottom navbar).
    finish() is called so back button cannot return to login.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <!-- Decorative top-right glow -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:paddingTop="64dp"
            android:gravity="center_horizontal">

            <!-- Brand -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conneqt"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <View
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/dot_accent" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Classroom Bridge"
                android:textSize="13sp"
                android:textColor="#4A90E2"
                android:letterSpacing="0.06"
                android:layout_marginBottom="48dp" />

            <!-- Login Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#141824">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign in to continue"
                        android:textSize="13sp"
                        android:textColor="#8892A4"
                        android:layout_marginBottom="32dp" />

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMAIL"
                        android:textSize="11sp"
                        android:textColor="#4A90E2"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:hint="professor@university.edu"
                        android:inputType="textEmailAddress"
                        android:padding="16dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#3D4557"
                        android:textSize="15sp"
                        android:background="@drawable/input_bg"
                        android:layout_marginBottom="20dp" />

                    <!-- Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PASSWORD"
                        android:textSize="11sp"
                        android:textColor="#4A90E2"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:padding="16dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#3D4557"
                        android:textSize="15sp"
                        android:background="@drawable/input_bg"
                        android:layout_marginBottom="28dp" />

                    <Button
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="SIGN IN"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:background="@drawable/btn_primary"
                        android:layout_marginBottom="16dp" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="#4A90E2" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sign Up Link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account? "
                    android:textSize="13sp"
                    android:textColor="#8892A4" />

                <TextView
                    android:id="@+id/tvGoToSignup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textSize="13sp"
                    android:textColor="#4A90E2"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="4dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conneqt v1.0  •  For Educators Only"
                android:textSize="11sp"
                android:textColor="#2A3147"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>